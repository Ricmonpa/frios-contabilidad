# Plantilla de secretos.
#
# EN LOCAL:  copia este archivo como  .streamlit/secrets.toml  y pon tu clave.
#            (secrets.toml está en .gitignore: nunca se sube a GitHub)
#
# EN STREAMLIT COMMUNITY CLOUD:  pega estas líneas en
#            App → Settings → Secrets  (con la clave real).
#
# Si no hay clave, el chat funciona con reglas (sin costo, sin LLM).

GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-2.5-flash"
